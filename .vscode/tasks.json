{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run EbonBuilds Tests",
            "type": "shell",
            "command": "./tests/lua51.exe",
            "args": ["tests/run.lua"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": {
                "owner": "lua",
                "fileLocation": "relative",
                "pattern": {
                    "regexp": "^tests/(.+\.lua):(\\d+):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "message": 3
                }
            }
        }
    ]
}
